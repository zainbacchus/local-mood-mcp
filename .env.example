# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
#
# Create an app at https://developer.spotify.com/dashboard.
# In the app settings, add this exact Redirect URI:
#     http://127.0.0.1:8888/callback
# (Spotify no longer accepts "localhost" — use the 127.0.0.1 loopback IP.)

SPOTIFY_CLIENT_ID=your_client_id_here

# OPTIONAL. With PKCE the client id alone is enough (public client). If you set
# a secret, the server uses it (confidential client) — slightly stronger, but
# keep it out of version control.
# SPOTIFY_CLIENT_SECRET=your_client_secret_here

# OPTIONAL. Must be a loopback http URI or an https URI, and must match the
# Redirect URI registered in the dashboard exactly.
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# OPTIONAL. Where to keep local state (tokens fallback + library cache).
# Defaults to ~/.spotify-mood-mcp
# SPOTIFY_MOOD_HOME=/Users/you/.spotify-mood-mcp
